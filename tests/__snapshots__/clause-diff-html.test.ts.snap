// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`renderClauseDiff > renders a self-contained fragment with a scoped style and header (golden) 1`] = `"<div class="clause-diff"><style>.clause-diff{color:#111111;font-family:serif;font-size:11px;}.clause-diff .clause-diff__header{font-weight:bold;margin-bottom:8px;}.clause-diff .clause-diff__empty{font-style:italic;color:#666666;}.clause-diff .diff-added{background:#e6ffed;padding:2px 4px;margin-bottom:2px;}.clause-diff .diff-removed{background:#ffeef0;padding:2px 4px;margin-bottom:2px;}.clause-diff .diff-replaced{padding:2px 4px;margin-bottom:2px;}.clause-diff del{background:#ffeef0;text-decoration:line-through;}.clause-diff ins{background:#e6ffed;text-decoration:none;}</style><div class="clause-diff__header">policy: v1 → v2</div><div class="diff-replaced"><del>The fee is 5%.</del><ins>The fee is 7%.</ins></div><div class="diff-added"><ins>Late payment incurs a penalty.</ins></div></div>"`;
