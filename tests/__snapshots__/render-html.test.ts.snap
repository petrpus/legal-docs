// Vitest Snapshot v1, https://vitest.dev/guide/snapshot.html

exports[`renderTreeToHtml > renders a self-contained fragment with a scoped style block (golden) 1`] = `"<div class="legal-doc"><style>.legal-doc{color:#111111;font-family:serif;font-size:11px;}.legal-doc .title{font-size:18px;font-weight:bold;margin:0 0 16px;}.legal-doc p{margin:0 0 8px;}.legal-doc .article{margin-bottom:6px;}.legal-doc .article[data-level="2"],.legal-doc .article[data-level="3"]{margin-left:14px;}.legal-doc .article__heading{font-weight:bold;margin-bottom:8px;}.legal-doc .article[data-level="1"]>.article__heading{font-size:13px;}.legal-doc .article[data-level="2"]>.article__heading{font-size:12px;}.legal-doc .article[data-level="3"]>.article__heading{font-size:11px;}.legal-doc .list{margin:0 0 4px 14px;}.legal-doc .list--alpha{list-style-type:lower-alpha;}.legal-doc .party{margin-bottom:8px;}.legal-doc .party__role{font-weight:bold;font-size:11px;}.legal-doc .kv{border-collapse:collapse;border-top:1px solid #999999;margin-bottom:8px;}.legal-doc .kv th,.legal-doc .kv td{border-bottom:1px solid #999999;padding:4px;font-size:10px;text-align:left;vertical-align:top;}.legal-doc .kv th{width:140px;}.legal-doc .signatures{display:flex;gap:24px;margin-top:16px;}.legal-doc .sig{flex:1;}.legal-doc .sig__line{border-top:1px solid #111111;margin-top:28px;margin-bottom:4px;}.legal-doc .sig__name{font-size:10px;}.legal-doc .sig__role{font-size:10px;color:#555555;}.legal-doc .legal-doc__unsupported{color:#b00020;font-style:italic;}</style><h1 class="title">AGREEMENT &amp; TERMS</h1><p>Plain &lt;world&gt; text</p><div class="rich"><p>This is <strong>bold</strong> and <em>italic</em>.</p></div><section class="article" data-level="1"><div class="article__heading">1. Definitions</div><p>Body.</p></section><ol class="list"><li><p>first</p></li><li><p>second</p></li></ol><div class="party"><div class="party__role">Lender</div><div class="party__name">Acme &amp; Co</div><div>123</div></div><table class="kv"><tbody><tr><th>Amount</th><td>EUR 100</td></tr></tbody></table><div class="signatures"><div class="sig"><div class="sig__line"></div><div class="sig__name">Jane Doe</div><div class="sig__role">Borrower</div></div></div></div>"`;
