{
  "_comment": "Baseline permissions + deny for code-dev projects using claude-code-harness. Copy to .claude/settings.json in the project, then add project-specific WebFetch domains / Read paths / extra allows on top.",
  "permissions": {
    "allow": [
      "Edit(**/*.md)",
      "Write(**/*.md)",
      "Bash(rm **/*.md)",

      "Bash(pnpm:*)",
      "Bash(npm run:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(tsx:*)",

      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git branch*)",
      "Bash(git checkout *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git push *)",
      "Bash(git rebase *)",
      "Bash(git stash*)",

      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh api *)",
      "Bash(gh repo *)",

      "Bash(docker:*)",
      "Bash(docker compose:*)",
      "Bash(prisma:*)",
      "Bash(playwright:*)",
      "Bash(vitest:*)",

      "Edit(app/**)",
      "Write(app/**)",
      "Edit(tests/**)",
      "Write(tests/**)",
      "Edit(scripts/**)",
      "Write(scripts/**)",
      "Edit(prisma/**)",
      "Write(prisma/**)",
      "Edit(public/**)",
      "Write(public/**)",
      "Edit(*.config.{ts,js,json})",
      "Write(*.config.{ts,js,json})",
      "Edit(package.json)",
      "Write(package.json)",
      "Edit(.gitignore)",
      "Write(.gitignore)",
      "Edit(.env.example)",
      "Write(.env.example)",
      "Edit(.claude/**)",
      "Write(.claude/**)",
      "Edit(.github/**)",
      "Write(.github/**)",
      "Edit(tmp/**)",
      "Write(tmp/**)",

      "WebSearch",
      "WebFetch(domain:github.com)",
      "WebFetch(domain:raw.githubusercontent.com)",
      "WebFetch(domain:reactrouter.com)",
      "WebFetch(domain:www.prisma.io)",
      "WebFetch(domain:tailwindcss.com)",
      "WebFetch(domain:ui.shadcn.com)"
    ],
    "deny": [
      "Bash(git push *--force*)",
      "Bash(git push *-f*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(rm -rf /*)",
      "Bash(rm -rf .git*)",
      "Write(.env)",
      "Edit(.env)"
    ],
    "additionalDirectories": ["/tmp"]
  }
}
